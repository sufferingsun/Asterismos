<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_horizontal">

        <LinearLayout
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:background="@drawable/paper">

            <ImageView
                android:id="@+id/constellation_image"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="400dp"
                android:layout_margin="20dp"
                android:background="@color/dark_gray_for_constellations"
                android:src="@drawable/imgand"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/dark_gray_for_constellations"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <Button
                android:id="@+id/first_choise"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_margin="10dp"
                android:background="@drawable/paper"
                app:backgroundTint="@null"
                android:fontFamily="@font/papyrus02"
                android:textColor="@color/dark_blue"
                android:textSize="25sp"/>

            <Button
                android:id="@+id/second_choise"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_margin="10dp"
                android:background="@drawable/paper"
                app:backgroundTint="@null"
                android:fontFamily="@font/papyrus02"
                android:textColor="@color/dark_blue"
                android:textSize="25sp"/>

            <Button
                android:id="@+id/third_choise"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_margin="10dp"
                android:background="@drawable/paper"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:fontFamily="@font/papyrus02"
                android:textColor="@color/dark_blue"
                android:textSize="25sp"/>

            <Button
                android:id="@+id/fourth_choise"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_margin="10dp"
                android:background="@drawable/paper"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:fontFamily="@font/papyrus02"
                android:textColor="@color/dark_blue"
                android:textSize="25sp"/>


        </LinearLayout>


        <View
            style="@style/EmptySpace"/>

    </LinearLayout>

</ScrollView>