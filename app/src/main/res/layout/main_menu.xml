<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/background">

    <ImageView
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="center"
        android:layout_marginBottom="200dp"
        android:src="@drawable/test1" />

    <ImageView
        android:layout_width="600dp"
        android:layout_height="600dp"
        android:layout_gravity="center"
        android:layout_marginTop="270dp"
        android:src="@drawable/circle"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textSize="50sp"
        android:layout_marginTop="80dp"
        android:textColor="@color/dark_gray_for_constellations"
        android:text="@string/app_name"
        android:fontFamily="@font/papyrus02"/>

    <TextView
        style="@style/TextForMenuIcons"
        android:layout_gravity="left"
        android:layout_marginTop="750dp"
        android:layout_marginLeft="40dp"
        android:text="Настройки"/>

    <TextView
        style="@style/TextForMenuIcons"
        android:layout_gravity="center"
        android:layout_marginTop="235dp"
        android:text="Энциклопедия"/>

    <TextView
        style="@style/TextForMenuIcons"
        android:layout_gravity="right"
        android:layout_marginTop="750dp"
        android:layout_marginRight="65dp"
        android:text="Тесты"/>

    <ImageButton
        android:id="@+id/settings"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:scaleType="fitCenter"
        android:background="@null"
        android:layout_marginStart="40dp"
        android:layout_marginTop="650dp"
        android:src="@drawable/settingsicon" />

    <ImageButton
        android:id="@+id/test"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:scaleType="fitCenter"
        android:background="@null"
        android:layout_gravity="right"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="650dp"
        android:src="@drawable/testicon" />

    <ImageButton
        android:id="@+id/encyclopedia"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:scaleType="fitCenter"
        android:background="@null"
        android:layout_gravity="center"
        android:layout_marginTop="180dp"
        android:src="@drawable/encyclicon"/>



</FrameLayout>